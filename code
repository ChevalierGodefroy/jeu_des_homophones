    def contenu_bouton(n):
        couleur_bordure, etat, resultat = caracteristiques_niveaux[n]

        if etat == "verrouille":
            texte_bouton = "🔒\ufe0f"
            couleur_fond = "#150ba1"

        elif resultat == "en cours":
            texte_bouton = f"{n}"
            couleur_fond = "#b039db"

        else: #etat == "deverrouille" and etal != "en cours"
            texte_bouton = f"{n}"
            if resultat == "reussi":
                couleur_fond = "#7be38c"
            else: #resultat == "echoue"
                couleur_fond = "#f24e61"

        return texte_bouton, couleur_fond, codes_couleurs_niveaux[couleur_bordure]


