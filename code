codes_couleurs_niveaux = {"vert": "#34ed69", "jaune": "#e6db1c", "orange": "#fc9423", "rouge": "#fc2332"}



if page_actuelle == "Page de présentation":

    st.markdown("<h1 style='text-align: center; font-size: 40px; margin-top: -60px; margin-bottom: 20px; color: #4287f5; '>Jeu des homophones</h1>", unsafe_allow_html=True)
    st.markdown("<h1 style='text-align: justify; font-size: 18px; font-weight: normal; line-height: 1.5; '>"
                "Bienvenue à ce défi linguistique !<br><br>"
