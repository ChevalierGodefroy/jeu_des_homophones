    st.markdown("<h1 style='text-align: center; font-size: 40px; margin-top: -60px; margin-bottom: -40px; color: #57ebc3 ;'>Carte des niveaux</h1>", unsafe_allow_html=True)

    col1, col2 = st.columns([5.5, 1.5])
    with col2:
        st.markdown(f"<h1 style='text-align: left; font-size: 20px; margin-bottom: 40px; font-weight: 650'>{st.session_state.nombre_etoiles} ⭐</h1>", unsafe_allow_html=True)

    caracteristiques_niveaux = {1: ["vert", "deverrouille", "reussi"], 2: ["vert", "deverrouille", "echoue"], 3: ["vert", "deverrouille", "reussi"], 4: ["jaune", "deverrouille", "reussi"],
                                5: ["jaune", "deverrouille", "echoue"], 6: ["jaune", "deverrouille", "reussi"], 7: ["orange", "deverrouille", "en cours"], 8: ["orange", "verrouille", "non evalue"],
